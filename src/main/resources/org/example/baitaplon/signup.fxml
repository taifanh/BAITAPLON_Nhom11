<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #3498db;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.baitaplon.signupcontroller">
   <children>
      <Pane prefHeight="400.0" prefWidth="519.0" style="-fx-background-color: white;">
         <children>
            <Label prefHeight="34.0" prefWidth="519.0" style="-fx-background-color: #3498db;" text="                                                     REGISTER ACCOUNT" textFill="#d40b0b">
               <font>
                  <Font name="System Bold Italic" size="14.0" />
               </font>
            </Label>
            <Button fx:id="signup_ok" layoutX="350.0" layoutY="310.0" mnemonicParsing="false" onAction="#handle_signup_ok" prefHeight="34.0" prefWidth="69.0" style="-fx-background-color: green;" text="OK">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
            <TextField fx:id="txtphonenumberup" layoutX="119.0" layoutY="74.0" prefHeight="25.0" prefWidth="300.0" promptText="PHONE NUMBER" />
            <TextField fx:id="txtnameup" layoutX="119.0" layoutY="128.0" prefHeight="25.0" prefWidth="300.0" promptText="USERNAME" />
            <TextField fx:id="txtemailup" layoutX="119.0" layoutY="180.0" prefHeight="25.0" prefWidth="300.0" promptText="EMAIL" />
            <PasswordField fx:id="txtpassup" layoutX="119.0" layoutY="244.0" prefHeight="25.0" prefWidth="300.0" promptText="PASSWORD" />
         </children>
      </Pane>
   </children>
</AnchorPane>
