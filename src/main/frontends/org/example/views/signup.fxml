<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="550.0" prefWidth="500.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.frontendcontrollers.signupcontroller">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="50.0" layoutY="45.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 25; -fx-padding: 40;">
         <effect>
            <DropShadow blurType="GAUSSIAN" height="50.0" radius="24.5" width="50.0">
               <color>
                  <Color red="0.0" green="0.0" blue="0.0" opacity="0.08" />
               </color>
            </DropShadow>
         </effect>
         <children>
            <Label text="ĐĂNG KÝ TÀI KHOẢN" textFill="#2C3E50">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="15.0" />
               </VBox.margin>
            </Label>

            <VBox spacing="18.0">
               <children>
                  <TextField fx:id="txtphonenumberup" prefHeight="40.0" promptText="Số điện thoại" style="-fx-background-color: transparent; -fx-border-color: #BDC3C7; -fx-border-width: 0 0 1 0; -fx-padding: 5 0 5 0;">
                     <font> <Font size="14.0" /> </font>
                  </TextField>

                  <TextField fx:id="txtnameup" prefHeight="40.0" promptText="Tên người dùng" style="-fx-background-color: transparent; -fx-border-color: #BDC3C7; -fx-border-width: 0 0 1 0; -fx-padding: 5 0 5 0;">
                     <font> <Font size="14.0" /> </font>
                  </TextField>

                  <TextField fx:id="txtemailup" prefHeight="40.0" promptText="Địa chỉ Email" style="-fx-background-color: transparent; -fx-border-color: #BDC3C7; -fx-border-width: 0 0 1 0; -fx-padding: 5 0 5 0;">
                     <font> <Font size="14.0" /> </font>
                  </TextField>

                  <PasswordField fx:id="txtpassup" prefHeight="40.0" promptText="Mật khẩu" style="-fx-background-color: transparent; -fx-border-color: #BDC3C7; -fx-border-width: 0 0 1 0; -fx-padding: 5 0 5 0;">
                     <font> <Font size="14.0" /> </font>
                  </PasswordField>
               </children>
            </VBox>

            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button fx:id="signup_ok" onAction="#handle_signup_ok" maxWidth="1.7976931348623157E308" prefHeight="48.0" style="-fx-background-color: #E67E22; -fx-background-radius: 30; -fx-cursor: hand;" text="XÁC NHẬN ĐĂNG KÝ" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </Button>

                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label text="Bạn đã có tài khoản?" textFill="#7F8C8D" />
                        <Button mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;" text="Đăng nhập" textFill="#E67E22">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>