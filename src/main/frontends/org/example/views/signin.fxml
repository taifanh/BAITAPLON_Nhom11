<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="450.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.signincontroller">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="45.0" layoutY="50.0" prefWidth="360.0" spacing="30.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 25; -fx-padding: 45;">
         <effect>
            <DropShadow blurType="GAUSSIAN" height="40.0" radius="19.5" width="40.0">
               <color>
                  <Color opacity="0.1" />
               </color>
            </DropShadow>
         </effect>
         <children>
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label text="WELCOME BACK" textFill="#2C3E50">
                     <font>
                        <Font name="System Bold" size="26.0" />
                     </font>
                  </Label>
                  <Label text="Please login to your account" textFill="#95A5A6">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Label>
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </VBox>

            <VBox spacing="20.0">
               <children>
                  <TextField fx:id="txtphonenumberfield" prefHeight="45.0" promptText="Số điện thoại" style="-fx-background-color: transparent; -fx-border-color: #DCDDE1; -fx-border-width: 0 0 1 0; -fx-padding: 5 0 5 0;">
                     <font>
                        <Font size="15.0" />
                     </font>
                  </TextField>
                  <PasswordField fx:id="txtpassfield" prefHeight="45.0" promptText="Mật khẩu" style="-fx-background-color: transparent; -fx-border-color: #DCDDE1; -fx-border-width: 0 0 1 0; -fx-padding: 5 0 5 0;">
                     <font>
                        <Font size="15.0" />
                     </font>
                  </PasswordField>
               </children>
            </VBox>

            <VBox spacing="15.0">
               <children>
                  <Button fx:id="signinbtn" defaultButton="true" maxWidth="1.7976931348623157E308" onAction="#handle_signin" prefHeight="50.0" style="-fx-background-color: #E67E22; -fx-background-radius: 30; -fx-cursor: hand;" text="ĐĂNG NHẬP" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                     <effect>
                        <DropShadow height="10.0" radius="4.5" width="10.0">
                           <color>
                              <Color red="0.9176470637321472" green="0.3450980484485626" blue="0.0470588244497776" opacity="0.3" />
                           </color>
                        </DropShadow>
                     </effect>
                  </Button>

                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label text="Chưa có tài khoản?" textFill="#7F8C8D" />
                        <Button fx:id="signupbtn" mnemonicParsing="false" onAction="#handle_signup" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;" text="Đăng ký ngay" textFill="#EA580C">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Button>
                     </children>
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </HBox>
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>